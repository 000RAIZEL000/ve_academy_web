# Copiar como .env y ajustar los valores
# Para desarrollo local rapido (SQLite) basta con estas dos lineas:
SECRET_KEY=django-insecure-dev-key-change-in-production-xyz123
DEBUG=True
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production

ALLOWED_HOSTS=localhost,127.0.0.1

# --- MySQL local (XAMPP) ---
# Descomenta estas lineas si quieres usar MySQL en lugar de SQLite:
# DB_NAME=ve_academy_db
# DB_USER=root
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306

# --- Produccion (Railway / PostgreSQL) ---
# Railway asigna DATABASE_URL automaticamente. Solo agrega:
# SECRET_KEY=clave-secreta-larga-y-aleatoria
# DEBUG=False
# DATABASE_URL=postgresql://user:password@host:port/dbname
# ALLOWED_HOSTS=tu-app.railway.app
# CSRF_TRUSTED_ORIGINS=https://tu-app.railway.app
