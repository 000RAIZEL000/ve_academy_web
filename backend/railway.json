{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "releaseCommand": "python manage.py migrate --noinput && python manage.py poblar_db",
    "startCommand": "gunicorn ve_academy.wsgi --bind 0.0.0.0:$PORT --workers 2 --timeout 120",
    "healthcheckPath": "/api/libros/",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
